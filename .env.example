# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_APP_VERSION=0.1.0

# Sentry (web)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENV=production
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=ftth-web
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Sentry (mobile) — used by app.config.ts → extra.sentryDsn
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# Mobile API URL (set per environment in eas.json)
EXPO_PUBLIC_API_URL=https://ftth.vercel.app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# E2E tests (optional)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=yourpassword
